#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/*
 * Слабее и стабильнее:
 * MOVE_VAL — скорость увода курсора вправо.
 * SCRL_VAL — сила колесика.
 *
 * Было 160 и 3 импульса. Сейчас 65 и 1 импульс.
 */
#define ZMK_POINTING_DEFAULT_MOVE_VAL 2200
#define ZMK_POINTING_DEFAULT_SCRL_VAL 65

#include <dt-bindings/zmk/pointing.h>

/ {
    macros {
        /*
         * 006 / P0.06:
         * Увести курсор вправо -> 10 ms влево в hitbox -> один короткий wheel-scroll.
         * Направление инвертировано обратно: SCRL_DOWN вместо SCRL_UP.
         * Никакого drag, никакого ЛКМ, только колесико.
         */
        next_video_wheel_safe: next_video_wheel_safe {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <35>;
            tap-ms = <25>;

            bindings
                /* курсор вправо */
                = <&macro_tap_time 450>
                , <&macro_tap &mmv MOVE_RIGHT>

                /* маленький возврат влево, чтобы попасть в hitbox приложения */
                , <&macro_wait_time 25>
                , <&macro_tap_time 10>
                , <&macro_tap &mmv MOVE_LEFT>

                /* пауза перед колесиком */
                , <&macro_wait_time 70>

                /* один короткий wheel-scroll в другую сторону */
                , <&macro_tap_time 25>
                , <&macro_tap &msc SCRL_DOWN>

                /*
                 * Пауза после wheel-события.
                 * Это не удержание, а наоборот "дать приложению отпустить анимацию".
                 */
                , <&macro_wait_time 220>

                /* вернуть обычную длительность */
                , <&macro_tap_time 35>
                ;
        };

        /*
         * 008 / P0.08:
         * Лайк — двойной клик. Не трогаем.
         */
        like_double_click: like_double_click {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <90>;
            tap-ms = <40>;

            bindings
                = <&macro_tap &mkp LCLK>
                , <&macro_wait_time 90>
                , <&macro_tap &mkp LCLK>
                ;
        };
    };

    combos {
        compatible = "zmk,combos";

        bt_clear_combo {
            timeout-ms = <100>;
            key-positions = <0 1>;
            bindings = <&bt BT_CLR>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &next_video_wheel_safe  /* 006 / P0.06 — безопасный wheel-scroll */
                &like_double_click      /* 008 / P0.08 — лайк */
            >;
        };
    };
};
